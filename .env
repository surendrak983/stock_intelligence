# ── Telegram Bot ──────────────────────────────────────────────────────────────
TG_BOT_TOKEN=your_bot_token_from_botfather
TG_CHAT_ID=your_chat_id_or_group_id

# ── Email (SMTP) ──────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=yourname@gmail.com
SMTP_PASS=your_app_password        # Gmail App Password (not your account password)
ALERT_EMAIL=recipient@example.com

# ── WhatsApp (Twilio) ─────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
ALERT_WHATSAPP_TO=whatsapp:+919XXXXXXXXX

# ── Anthropic (optional AI enrichment) ───────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Web Dashboard ─────────────────────────────────────────────────────────────
DASHBOARD_PORT=5000
